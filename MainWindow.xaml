<Window x:Class="sannsuuApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:sannsuuApp"
        mc:Ignorable="d"

        Title="小学生算数アプリ" Height="450" Width="400">
        <StackPanel Margin="20" HorizontalAlignment="Center">
            <TextBlock Text="がくねんを えらんでね" FontSize="18" Margin="0,0,0,10"/>
            <ComboBox x:Name="GradeSelector" SelectedIndex="0" Margin="0,0,0,20">
                <ComboBoxItem Content="1年生"/>
                <ComboBoxItem Content="2年生"/>
                <ComboBoxItem Content="3年生"/>
                <ComboBoxItem Content="4年生"/>
                <ComboBoxItem Content="5年生"/>
                <ComboBoxItem Content="6年生"/>
            </ComboBox>

            <Button Content="スタート / つぎの問題" Click="NextButton_Click" Height="40"/>

            <TextBlock x:Name="QuestionLabel" Text="---" FontSize="36" Margin="0,40" HorizontalAlignment="Center"/>

            <TextBox x:Name="AnswerBox" FontSize="24" Width="100" HorizontalContentAlignment="Center"/>

            <Button Content="こたえあわせ" Click="CheckButton_Click" Margin="0,20" Height="40" Background="LightBlue"/>

            <TextBlock x:Name="ResultLabel" Text="" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
        </StackPanel>
    
</Window>
